{
  "name": "@qontinui/wrapper-v0",
  "version": "0.1.0",
  "description": "UI Bridge wrapper — Vercel v0 (api-primary with Playwright fallback).",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./node": {
      "types": "./dist/index-node.d.ts",
      "import": "./dist/index-node.js",
      "require": "./dist/index-node.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "echo \"(no lint configured)\"",
    "clean": "rimraf dist coverage"
  },
  "peerDependencies": {
    "@qontinui/ui-bridge": "*",
    "@qontinui/ui-bridge-wrapper": "*",
    "playwright": "^1.49.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "playwright": {
      "optional": true
    }
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@qontinui/_testing-harness": "workspace:*",
    "@qontinui/_tsconfig": "workspace:*",
    "@qontinui/ui-bridge": "file:../../../ui-bridge/packages/ui-bridge",
    "@qontinui/ui-bridge-wrapper": "file:../../../ui-bridge/packages/ui-bridge-wrapper",
    "@types/node": "^20.10.0",
    "@types/react": "^19.0.0",
    "playwright": "^1.49.0",
    "react": "^19.0.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "qontinui": {
    "wrapper": {
      "manifestVersion": 1,
      "id": "v0",
      "displayName": "Vercel v0",
      "description": "Generate React components with Vercel v0 from a natural-language prompt",
      "transport": "api",
      "categories": ["ai", "frontend"],
      "envVars": [
        {
          "name": "V0_ACCESS_TOKEN",
          "required": true,
          "secret": true,
          "description": "v0 API token from https://v0.app/account"
        }
      ]
    }
  }
}

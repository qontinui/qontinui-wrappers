# Vercel v0 API access token — issue one from your Vercel account settings.
V0_ACCESS_TOKEN=

# Optional: override the API base URL during local development.
V0_API_BASE_URL=https://api.v0.dev

# Playwright fallback only. Pre-warm a signed-in storage state via
# `npx playwright open --save-storage=./v0-storage.json https://v0.app`
# and point at the resulting JSON file.
V0_STORAGE_STATE_PATH=
V0_BASE_URL=https://v0.app

{
  "name": "@qontinui/wrapper-gmail",
  "version": "0.1.0",
  "description": "UI Bridge wrapper — Gmail REST API (api transport only).",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./node": {
      "types": "./dist/index-node.d.ts",
      "import": "./dist/index-node.js",
      "require": "./dist/index-node.cjs"
    }
  },
  "bin": {
    "gmail-oauth-setup": "./dist/scripts/oauth-setup.cjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "echo \"(no lint configured)\"",
    "clean": "rimraf dist coverage"
  },
  "peerDependencies": {
    "@qontinui/ui-bridge": "*",
    "@qontinui/ui-bridge-wrapper": "*",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "googleapis": "^144.0.0"
  },
  "devDependencies": {
    "@qontinui/_testing-harness": "workspace:*",
    "@qontinui/_tsconfig": "workspace:*",
    "@qontinui/ui-bridge": "file:../../../ui-bridge/packages/ui-bridge",
    "@qontinui/ui-bridge-wrapper": "file:../../../ui-bridge/packages/ui-bridge-wrapper",
    "@types/node": "^20.10.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "qontinui": {
    "wrapper": {
      "manifestVersion": 1,
      "id": "gmail",
      "displayName": "Gmail",
      "description": "Read, search, reply to, and archive Gmail messages via the Gmail REST API",
      "transport": "api",
      "categories": ["productivity", "email"],
      "envVars": [
        {
          "name": "GMAIL_OAUTH_CLIENT_ID",
          "required": true,
          "secret": true,
          "description": "OAuth 2.0 client ID from Google Cloud Console"
        },
        {
          "name": "GMAIL_OAUTH_CLIENT_SECRET",
          "required": true,
          "secret": true,
          "description": "OAuth 2.0 client secret from Google Cloud Console"
        },
        {
          "name": "GMAIL_REFRESH_TOKEN",
          "required": true,
          "secret": true,
          "description": "OAuth refresh token (run `gmail-oauth-setup` to obtain one)"
        }
      ]
    }
  }
}

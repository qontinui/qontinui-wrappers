# OAuth2 credentials for the Gmail wrapper.
# Provision the refresh token once via the bundled loopback helper:
#   pnpm --filter @qontinui/wrapper-gmail exec gmail-oauth-setup
# (see README for the full flow), then keep these values in your local .env
# only — never check the real values in.

GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Optional: override the default "me" user id used for gmail.users.* calls.
GMAIL_USER_ID=me
